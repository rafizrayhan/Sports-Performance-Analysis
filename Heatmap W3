import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# importing the data
MLBAM18=pd.read_csv("")
print(MLBAM18.columns.tolist())

# limiting the set of variables
MLBmap=MLBAM18[['']]
MLBmap['event'].unique()

# plotting the coordinates
plt.scatter(MLBmap['our.x'],MLBmap['our.y'],s=.001,c='r',marker='.')

# plotting subset (hit)
Single=MLBmap[MLBmap.event=='Single']
plt.scatter(Single['our.x'],Single['our.y'],s=.02,c='darkorange',marker='.')

# plotting subset (double)
Double=MLBmap[MLBmap.event=='Double']
plt.scatter(Double['our.x'],Double['our.y'],s=.02,c='dodgerblue',marker='.')

# plotting subset (triple)
Triple=MLBmap[MLBmap.event=='Triple']
plt.scatter(Triple['our.x'],Triple['our.y'],s=.02,c='',marker='.')

# plotting home runs
Homer=MLBmap[MLBmap.event=='Home Run']
plt.scatter(Homer['our.x'],Homer['our.y'],s=.20,c='m',marker='.')

# four plots
fig.axes=plt.subplots(1,4,figsize=(15,3))
axes[0].scatter(Single['our.x'],Single['our.y'],s=.01,c='darkorange',marker='.')
axes[0].set_ylim((0,500))
axes[0].set_title('Singles')

axes[1].scatter(Double['our.x'],Double['our.y'],s=.01,c='dodgerblue',marker='.')
axes[1].set_ylim((0,500))
axes[1].set_title('Doubles')

axes[2].scatter(Triple['our.x'],Triple['our.y'],s=1,c='g',marker='.')
axes[2].set_ylim((0,500))
axes[2].set_title('Triples')

axes[3].scatter(Homer['our.x'],Homer['our.y'],s=.5,c='m',marker='.')
axes[3].set_ylim((0,500))
axes[3].set_title('Home Runs')

plt.tight_layout()
plt.show()

#on the same chart
