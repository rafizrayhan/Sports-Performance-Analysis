ax=plt.scatter(Double['our.x'],Double['our.y'],s=.1,c='dodgerblue',marker='.')
ax=plt.scatter(Triple['our.x'],Triple['our.y'],s=1,c='g',marker='.')
ax=plt.scatter(Homer['our.x'],Homer['our.y'],s=.5,c='m',marker='.')

